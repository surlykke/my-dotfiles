#!/usr/bin/env bash

#swayidle -w \
#	timeout 180 gtklock \
#	before-sleep gtklock
#
export MARKER=$XDG_RUNTIME_DIR/count-down-marker
exec swayidle -w \
	before-sleep  lockScreen \
	timeout 170 "notify-send -r 14238736 -t 9799 -i dialog-information 'Skærm låser snart' ''" \
		resume "notify-send -r 14238736 -t 1 -i dialog-information 'Skærm låser snart' ''" \
	timeout 180 "lockScreen 3" \
	timeout 600 "niri msg action power-off-monitors"

