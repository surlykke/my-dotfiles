#!/usr/bin/env bash

#swayidle -w \
#	timeout 180 gtklock \
#	before-sleep gtklock
#
export MARKER=$XDG_RUNTIME_DIR/count-down-marker
exec swayidle -w \
	before-sleep "gtklock -d" \
	timeout 160 "touch $MARKER; lockCountDown 20 $MARKER &" \
		resume "rm $MARKER" \
	timeout 180 lockScreen \
	timeout 600 "niri msg action power-off-monitors"

