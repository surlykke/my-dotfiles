#!/usr/bin/env bash
if [[ -n "$1" ]]; then
	fadein="--fade-in $1"
fi

if [[ -n "$2" ]]; then
	fadein="$fadein --grace $2"
fi

nohup swaylock $fadein\
	--screenshots \
	--clock \
	--indicator \
	--indicator-radius 100 \
	--indicator-thickness 7 \
	--effect-blur 12x8 \
	--effect-vignette 0.5:0.5 \
	--ring-color bb00cc \
	--key-hl-color 880033 \
	--line-color 00000000 \
	--inside-color 00000088 \
	--separator-color 00000000 >/dev/null 2>/dev/null &
